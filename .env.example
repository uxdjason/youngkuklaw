# AI API Keys
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# 우선순위 모델 (override 가능)
PRIMARY_MODEL=claude-sonnet-4-6
SECONDARY_MODEL=claude-haiku-4-5-20251001
HEAVY_MODEL=claude-opus-4-7
FALLBACK_MODEL=gemini-2.5-pro

# WordPress export source
WP_EXPORT_PATH=./legacy-source/wordpress-export/youngkuklaw.WordPress.xml
WP_BASE_URL=https://youngkuklaw.com

# 마이그레이션 동시성
MAX_CONCURRENT_AI_CALLS=4
MAX_CONCURRENT_REVIEW_QUEUE=20

# 발행 시간 분산
PUBLISH_MAX_PER_DAY=5
PUBLISH_GAP_MIN_HOURS=2
PUBLISH_GAP_MAX_HOURS=3

# Streamlit
REVIEWER_PORT=8501
