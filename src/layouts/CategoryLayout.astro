---
import BaseLayout from "./BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CategorySlug } from "../content.config";
import type { Lang } from "../utils/i18n";
import { CATEGORY_LABELS } from "../utils/i18n";
import AdSlot from "../components/AdSlot.astro";

interface Props {
  lang: Lang;
  category: CategorySlug;
}

const { lang, category } = Astro.props;

// Fetch posts that belong to this category and language, and are not drafts
const allPosts = await getCollection("posts", ({ data }) => {
  if (data.lang !== lang || data.draft) return false;

  if (category === "case-law") {
    // case-law page aggregates all cases from *-cases categories
    return data.category.endsWith("-cases") || data.category === "case-law";
  }

  return data.category === category;
});

// Helper function to extract citation year
function getCitationYear(citation?: string, pubDate?: Date): number {
  if (!citation) {
    return pubDate ? pubDate.getFullYear() : 0;
  }
  // Try to find a 4-digit year in brackets or parentheses first: e.g. [1953] or (1220)
  const bracketMatch = citation.match(/[\(\[](\d{4})[\)\]]/);
  if (bracketMatch) {
    return parseInt(bracketMatch[1], 10);
  }
  // Fallback to any 4-digit number starting with 1 or 2
  const fourDigitMatch = citation.match(/\b(1\d{3}|20\d{2})\b/);
  if (fourDigitMatch) {
    return parseInt(fourDigitMatch[1], 10);
  }
  const twoDigitMatch = citation.match(/\b\d+\/(\d{2})\b/);
  if (twoDigitMatch) {
    const yr = parseInt(twoDigitMatch[1], 10);
    return yr >= 50 ? 1900 + yr : 2000 + yr;
  }
  return pubDate ? pubDate.getFullYear() : 0;
}

const isCaseCategory = category === "case-law" || category.endsWith("-cases");

// Sort posts: default is latest (citation year descending for cases, pubDate descending for notes)
const sortedPosts = allPosts.sort((a, b) => {
  if (isCaseCategory) {
    const yearA = getCitationYear(a.data.citation, a.data.pubDate);
    const yearB = getCitationYear(b.data.citation, b.data.pubDate);
    if (yearB !== yearA) {
      return yearB - yearA;
    }
    return a.data.title.localeCompare(b.data.title);
  } else {
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  }
});

const label = CATEGORY_LABELS[category][lang];
const totalCount = sortedPosts.length;

const unitText =
  lang === "en"
    ? isCaseCategory
      ? "cases"
      : "notes"
    : isCaseCategory
      ? "개 판례"
      : "개 노트";

const countLabel =
  lang === "en"
    ? `${totalCount} ${unitText} Available`
    : `${totalCount}${unitText} 이용 가능`;

// Extract unique keywords for the keyword cloud from the posts
const allKeywords = Array.from(
  new Set(sortedPosts.flatMap((post) => post.data.uiTags || [])),
);

// Date formatter helper
function formatDate(date: Date, locale: string) {
  return date.toLocaleDateString(locale === "ko" ? "ko-KR" : "en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

const allSortOptions = [
  {
    id: "latest",
    en: "Latest",
    ko: "최근 판례부터",
    caseOnly: true,
  },
  {
    id: "oldest",
    en: "Oldest",
    ko: "오래된 판례부터",
    caseOnly: true,
  },
  {
    id: "recently-added",
    en: "Recently Added",
    ko: "최근 추가 먼저",
    caseOnly: false,
  },
  {
    id: "most-popular",
    en: "Most Popular",
    ko: "조회수 기준",
    caseOnly: false,
  },
  {
    id: "alphabetical",
    en: "Alphabetical",
    ko: "알파벳 순서",
    caseOnly: false,
  },
];

// For case categories: show all 5 options (Latest active by default)
// For note categories: show only 3 options (Recently Added active by default)
const sortOptions = allSortOptions.filter(
  (opt) => !opt.caseOnly || isCaseCategory,
);
const defaultSortId = isCaseCategory ? "latest" : "recently-added";

// Build richer SEO title and description for category pages
const isCaseCat = isCaseCategory;
const seoTitle =
  lang === "en"
    ? `${label} ${isCaseCat ? "Cases" : "Notes"} · YoungkukLaw`
    : `${label} ${isCaseCat ? "판례" : "노트"} · YoungkukLaw`;

const CATEGORY_INTROS: Record<string, { en: string; ko: string }> = {
  "english-law": {
    en: "Explore the foundations and development of English law.",
    ko: "영국법의 기초와 발전 과정을 학습합니다.",
  },
  "contract-law": {
    en: "Explore the principles governing contractual obligations.",
    ko: "영미 계약법의 다양한 원칙들과 법리들을 살펴보세요.",
  },
  "tort-law": {
    en: "Explore the law of civil liability and compensation.",
    ko: "불법행위에 대한 민사상 책임과 손해배상 및 항변에 관하여 학습합니다.",
  },
  "public-law": {
    en: "Explore the legal framework governing public power.",
    ko: "공권력의 행사와 통제를 규율하는 법체계를 살펴보세요.",
  },
  "criminal-law": {
    en: "Explore the principles of criminal liability and justice.",
    ko: "형사 책임과 형법의 여러 원칙들을 살펴보세요.",
  },
  "equity-law": {
    en: "Explore the equitable principles that complement the common law.",
    ko: "보통법의 한계를 보완하는 형평법의 원칙들을 학습합니다.",
  },
  "land-law": {
    en: "Explore the law governing rights and interests in land.",
    ko: "토지에 대한 권리와 이익을 규율하는 법리와 원칙들을 살펴보세요.",
  },
  "case-law": {
    en: "Browse cases from every major area of English law.",
    ko: "영국법의 주요 분야별 판례들을 한 곳에서 살펴보세요.",
  },
  "contract-law-cases": {
    en: "Browse leading cases in contract law.",
    ko: "영국 계약법의 주요 판례들을 살펴보세요.",
  },
  "tort-law-cases": {
    en: "Browse leading cases in tort law.",
    ko: "영국 불법행위법의 주요 판례들을 살펴보세요.",
  },
  "public-law-cases": {
    en: "Browse leading cases in public law.",
    ko: "영국 공법의 주요 판례들을 살펴보세요.",
  },
  "criminal-law-cases": {
    en: "Browse leading cases in criminal law.",
    ko: "영국 형법의 주요 판례들을 살펴보세요.",
  },
  "equity-law-cases": {
    en: "Browse leading cases in equity.",
    ko: "영국 형평법의 주요 판례들을 살펴보세요.",
  },
  "land-law-cases": {
    en: "Browse leading cases in land law.",
    ko: "영국 토지법의 주요 판례들을 살펴보세요.",
  },
};

const categoryIntro = CATEGORY_INTROS[category];

const seoDescription =
  lang === "en"
    ? `Browse ${totalCount} ${isCaseCat ? "case summaries" : "lecture notes"} for ${label}. Free, clear and well-structured English law resources for law students worldwide.`
    : `YoungkukLaw에서 ${label} 관련 ${isCaseCat ? "판례" : "노트"} ${totalCount}개를 무료로 제공합니다. 영국법 학습자를 위한 명확하고 체계적인 학습 자료입니다.`;
---

<BaseLayout lang={lang} title={seoTitle} description={seoDescription}>
  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="subject-hero-container">
          <div class="subject-hero-left">
            <h1 class="heading-style-h1">{label}</h1>
            <div class="spacer-small"></div>
            <div class="text-size-medium">
              {
                categoryIntro
                  ? lang === "en"
                    ? categoryIntro.en
                    : categoryIntro.ko
                  : lang === "en"
                    ? `Explore ${label}.`
                    : `${label} 살펴보기.`
              }
            </div>
          </div>
          <div class="subject-hero-right">
            <div class="text-block-5">{totalCount}</div>
            <div class="text-block-6">{unitText} Available</div>
          </div>
        </div>
        <div class="spacer-large"></div>
        <div class="hr-div no-margin"></div>
      </div>
    </div>
  </section>

  {
    category === "case-law" && (
      <section class="section">
        <div class="padding-global">
          <div class="container-large">
            <div class="spacer-large" />
            <div class="heading-style-h2">
              {lang === "en" ? "Cases by Subjects" : "과목별 판례"}
            </div>
            <div class="spacer-small" />
            <div class="case-subject-card-container">
              <div class="case-subject-card">
                <a
                  href={
                    lang === "en"
                      ? "/contract-law-cases/"
                      : "/ko/contract-law-cases/"
                  }
                  class="link-block w-inline-block"
                >
                  <div class="heading-style-h4">
                    {lang === "en" ? "Contract Law Cases" : "계약법 판례"}
                  </div>
                </a>
              </div>
              <div class="case-subject-card">
                <a
                  href={
                    lang === "en" ? "/tort-law-cases/" : "/ko/tort-law-cases/"
                  }
                  class="link-block w-inline-block"
                >
                  <div class="heading-style-h4">
                    {lang === "en" ? "Tort Law Cases" : "불법행위법 판례"}
                  </div>
                </a>
              </div>
              <div class="case-subject-card">
                <a
                  href={
                    lang === "en"
                      ? "/public-law-cases/"
                      : "/ko/public-law-cases/"
                  }
                  class="link-block w-inline-block"
                >
                  <div class="heading-style-h4">
                    {lang === "en" ? "Public Law Cases" : "공법 판례"}
                  </div>
                </a>
              </div>
              <div class="case-subject-card">
                <a
                  href={
                    lang === "en"
                      ? "/criminal-law-cases/"
                      : "/ko/criminal-law-cases/"
                  }
                  class="link-block w-inline-block"
                >
                  <div class="heading-style-h4">
                    {lang === "en" ? "Criminal Law Cases" : "형법 판례"}
                  </div>
                </a>
              </div>
              <div class="case-subject-card">
                <a
                  href={
                    lang === "en"
                      ? "/equity-law-cases/"
                      : "/ko/equity-law-cases/"
                  }
                  class="link-block w-inline-block"
                >
                  <div class="heading-style-h4">
                    {lang === "en" ? "Equity Law Cases" : "형평법 판례"}
                  </div>
                </a>
              </div>
              <div class="case-subject-card">
                <a
                  href={
                    lang === "en" ? "/land-law-cases/" : "/ko/land-law-cases/"
                  }
                  class="link-block w-inline-block"
                >
                  <div class="heading-style-h4">
                    {lang === "en" ? "Land Law Cases" : "토지법 판례"}
                  </div>
                </a>
              </div>
            </div>
            <div class="spacer-large" />
          </div>
        </div>
      </section>
    )
  }

  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="article-block">
          {/* Left Sidebar Filter Section */}
          <div class="article-list-left">
            <div class="sort-by">
              <div class="sort-by-upper">
                <div class="article-list-left-heading">
                  {lang === "en" ? "Sort by" : "정렬 방법"}
                </div>
              </div>
              <div class="sort-by-lower">
                {
                  sortOptions.map((opt) => (
                    <a
                      href="#"
                      class="sort-by-radio w-inline-block"
                      data-sort-type={opt.id}
                      data-active={opt.id === defaultSortId ? "true" : "false"}
                    >
                      <div class="radio-on w-embed">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          height="1em"
                          viewBox="0 -960 960 960"
                          width="1em"
                          fill="currentColor"
                        >
                          <path d="M621.5-338.5Q680-397 680-480t-58.5-141.5Q563-680 480-680t-141.5 58.5Q280-563 280-480t58.5 141.5Q397-280 480-280t141.5-58.5ZM480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Z" />
                        </svg>
                      </div>
                      <div class="radio-off w-embed">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          height="1em"
                          viewBox="0 -960 960 960"
                          width="1em"
                          fill="currentColor"
                        >
                          <path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Z" />
                        </svg>
                      </div>
                      <div
                        class={
                          opt.id === defaultSortId
                            ? "text-block-8"
                            : "text-block-9"
                        }
                      >
                        {lang === "en" ? opt.en : opt.ko}
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>

            <div class="sort-by">
              <div class="sort-by-upper">
                <div class="article-list-left-heading">
                  {lang === "en" ? "Keywords" : "핵심 키워드"}
                </div>
              </div>
              <div class="keyword-cloud" id="keyword-cloud-container">
                <a href="#" class="keyword-link w-inline-block">
                  <div class="keyword-tag all">
                    {lang === "en" ? "All" : "전체"}
                  </div>
                </a>
              </div>
              <script is:inline define:vars={{ allKeywords, lang }}>
                const container = document.getElementById("keyword-cloud-container");
                if (container && allKeywords.length > 0) {
                  let selected = [...allKeywords];
                  // If there are more than 20 keywords, randomly select 20
                  if (selected.length > 20) {
                    // Fisher-Yates shuffle
                    for (let i = selected.length - 1; i > 0; i--) {
                      const j = Math.floor(Math.random() * (i + 1));
                      const temp = selected[i];
                      selected[i] = selected[j];
                      selected[j] = temp;
                    }
                    selected = selected.slice(0, 20);
                  }
                  
                  // Sort alphabetically based on language
                  selected.sort((a, b) => a.localeCompare(b, lang === "ko" ? "ko" : "en"));
                  
                  selected.forEach((keyword) => {
                    const a = document.createElement("a");
                    a.href = "#";
                    a.className = "keyword-link w-inline-block";
                    const div = document.createElement("div");
                    div.className = "keyword-tag";
                    div.textContent = keyword;
                    a.appendChild(div);
                    container.appendChild(a);
                  });
                }
              </script>
            </div>

            <div class="sort-by">
              <div class="sort-by-upper">
                <div class="article-list-left-heading">
                  {lang === "en" ? "Bookmark" : "즐겨찾기"}
                </div>
              </div>
              <a href="#" class="bookmarked-only w-inline-block">
                <div class="bookmark-icon-off w-embed">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    height="1em"
                    viewBox="0 -960 960 960"
                    width="1em"
                    fill="currentColor"
                  >
                    <path
                      d="M200-120v-640q0-33 23.5-56.5T280-840h400q33 0 56.5 23.5T760-760v640L480-240 200-120Zm80-122 200-86 200 86v-518H280v518Zm0-518h400-400Z"
                    ></path>
                  </svg>
                </div>
                <div class="bookmark-icon-on w-embed">
                  <svg
                    width="1em"
                    height="1em"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <rect x="7" y="5" width="10" height="13" fill="#FFC400"
                    ></rect>
                    <path
                      d="M5 21V5C5 4.45 5.19583 3.97917 5.5875 3.5875C5.97917 3.19583 6.45 3 7 3H17C17.55 3 18.0208 3.19583 18.4125 3.5875C18.8042 3.97917 19 4.45 19 5V21L12 18L5 21ZM7 17.95L12 15.8L17 17.95V5H7V17.95Z"
                      fill="currentColor"></path>
                  </svg>
                </div>
                <div class="bookmarked-only-label">
                  {lang === "en" ? "Bookmarked Only" : "즐겨찾기한 글만 보기"}
                </div>
              </a>
            </div>

            <div class="google-adsense-placeholder">
              <AdSlot slot="category-sidebar-ad" />
            </div>
          </div>

          {/* Right Articles List Section */}
          <div class="article-list-wrapper">
            {
              totalCount === 0 ? (
                <div class="note-container">
                  <div class="div-block-2">
                    <div
                      class={`featured-content-desc${lang === "ko" ? " ko" : ""}`}
                    >
                      {lang === "en"
                        ? "No posts yet."
                        : "아직 게시된 글이 없습니다."}
                    </div>
                  </div>
                </div>
              ) : (
                <>
                  <div
                    class="note-container no-bookmark-filter-msg"
                    style="display:none"
                  >
                    <div class="div-block-2">
                      <div
                        class={`featured-content-desc${lang === "ko" ? " ko" : ""}`}
                      >
                        {lang === "en"
                          ? "You have no bookmarked article."
                          : "즐겨찾기에 추가된 내용이 없습니다."}
                      </div>
                    </div>
                  </div>
                  <div class="pagination-wrapper top-pagination"></div>
                  <div
                    class="article-list"
                    data-is-case-category={isCaseCategory ? "true" : "false"}
                  >
                    {sortedPosts.map((post) => (
                      <div
                        class="article-row"
                        data-pubdate={post.data.pubDate.valueOf()}
                        data-title={post.data.title.toLowerCase()}
                        data-views={(post.data as any).views || 0}
                        data-created={post.data.pubDate.valueOf()}
                        data-keywords={
                          post.data.uiTags?.join(",").toLowerCase() ||
                          ""
                        }
                        data-slug={post.data.slug}
                        data-citation-year={getCitationYear(
                          post.data.citation,
                          post.data.pubDate,
                        )}
                      >
                        <div class="article-row-upper">
                          <div class="keyword-tag-container">
                            {(post.data.uiTags || []).map((k) => (
                              <div class="keyword-tag">{k}</div>
                            ))}
                          </div>
                          <a
                            href="#"
                            class="bookmark w-inline-block"
                            data-slug={post.data.slug}
                          >
                            <div class="bookmark-empty w-embed">
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                height="1em"
                                viewBox="0 -960 960 960"
                                width="1em"
                                fill="currentColor"
                              >
                                <path d="M200-120v-640q0-33 23.5-56.5T280-840h400q33 0 56.5 23.5T760-760v640L480-240 200-120Zm80-122 200-86 200 86v-518H280v518Zm0-518h400-400Z" />
                              </svg>
                            </div>
                            <div class="bookmark-filled w-embed">
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                height="1em"
                                viewBox="0 0 24 24"
                                fill="none"
                              >
                                <rect
                                  x="7"
                                  y="5"
                                  width="10"
                                  height="13"
                                  fill="#FFC400"
                                />
                                <path
                                  d="M5 21V5C5 4.45 5.19583 3.97917 5.5875 3.5875C5.97917 3.19583 6.45 3 7 3H17C17.55 3 18.0208 3.19583 18.4125 3.5875C18.8042 3.97917 19 4.45 19 5V21L12 18L5 21ZM7 17.95L12 15.8L17 17.95V5H7V17.95Z"
                                  fill="currentColor"
                                />
                              </svg>
                            </div>
                          </a>
                        </div>
                        <div class="spacer-xsmall" />

                        {/* Title binding */}
                        <a
                          href={
                            lang === "en"
                              ? `/${post.data.slug}/`
                              : `/ko/${post.data.slug}/`
                          }
                          class="article-row-heading w-inline-block"
                        >
                          <h3
                            class={`heading-style-h3${lang === "ko" ? " ko" : ""}`}
                          >
                            {post.data.title}
                          </h3>
                          {isCaseCategory && post.data.citation && (
                            <div class="case-citation-text">
                              {post.data.citation}
                            </div>
                          )}
                        </a>

                        <div class="spacer-small" />
                        <div class="article-row-description">
                          <div
                            class={`featured-content-desc${lang === "ko" ? " ko" : ""}`}
                          >
                            {post.data.uiDescription || post.data.description}
                          </div>
                        </div>
                        <div class="spacer-small" />

                        <div class="article-row-lower">
                          <div class="article-row-lower-left">
                            <div class="view-number">
                              <div class="eye-icon w-embed">
                                <svg
                                  xmlns="http://www.w3.org/2000/svg"
                                  height="1em"
                                  viewBox="0 -960 960 960"
                                  width="1em"
                                  fill="currentColor"
                                >
                                  <path d="M607.5-372.5Q660-425 660-500t-52.5-127.5Q555-680 480-680t-127.5 52.5Q300-575 300-500t52.5 127.5Q405-320 480-320t127.5-52.5Zm-204-51Q372-455 372-500t31.5-76.5Q435-608 480-608t76.5 31.5Q588-545 588-500t-31.5 76.5Q525-392 480-392t-76.5-31.5ZM214-281.5Q94-363 40-500q54-137 174-218.5T480-800q146 0 266 81.5T920-500q-54 137-174 218.5T480-200q-146 0-266-81.5ZM480-500Zm207.5 160.5Q782-399 832-500q-50-101-144.5-160.5T480-720q-113 0-207.5 59.5T128-500q50 101 144.5 160.5T480-280q113 0 207.5-59.5Z" />
                                </svg>
                              </div>
                              <div
                                class="view-number-num view-counter-batch"
                                data-slug={post.data.slug}
                              >
                                0 views
                              </div>
                            </div>
                            <div class="note-row-timestamp">
                              {formatDate(post.data.pubDate, lang)}
                            </div>
                          </div>
                          <a
                            href={
                              lang === "en"
                                ? `/${post.data.slug}/`
                                : `/ko/${post.data.slug}/`
                            }
                            class="btn-read-more w-inline-block"
                          >
                            <div class="featured-content-desc">
                              {lang === "en" ? "Read More" : "자세히 보기"}
                            </div>
                          </a>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div class="pagination-wrapper bottom-pagination"></div>
                </>
              )
            }

            <div class="spacer-large"></div>
          </div>
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .sort-by-radio[data-active="true"] .radio-on {
    display: block;
  }
  .sort-by-radio[data-active="true"] .radio-off {
    display: none;
  }
  .sort-by-radio[data-active="false"] .radio-on {
    display: none;
  }
  .sort-by-radio[data-active="false"] .radio-off {
    display: block;
  }

  /* Active states for Bookmark filters */
  .bookmarked-only[data-active="true"] {
    color: var(--base-color-brand--yellow-dark) !important;
  }
  .bookmarked-only[data-active="true"] .bookmark-icon-off {
    display: none !important;
  }
  .bookmarked-only[data-active="true"] .bookmark-icon-on {
    display: block !important;
  }

  /* Active states for Keyword filters */
  .keyword-tag[data-active="true"] {
    background-color: var(--base-color-brand--blue-dark) !important;
    color: var(--text-color--text-alternate) !important;
  }
  .keyword-tag:not([data-active="true"]) {
    background-color: var(--base-color-brand--blue-light) !important;
    color: var(--base-color-brand--blue-dark) !important;
  }
  .keyword-tag.all:not([data-active="true"]) {
    color: var(--base-color-brand--blue-dark) !important;
    background-color: var(--base-color-brand--blue-light) !important;
  }

  /* Pagination Styles */
  .pagination-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin: 32px 0;
  }
  .pagination-wrapper.top-pagination {
    margin-top: 16px;
    margin-bottom: 24px;
  }
  .pagination-wrapper.bottom-pagination {
    margin-top: 24px;
    margin-bottom: 16px;
  }
  .page-btn {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 8px 12px;
    border: 1px solid var(--border-color--border-primary);
    background-color: transparent;
    color: var(--text-color--text-primary);
    border-radius: 4px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .page-btn:hover:not(:disabled):not(.active) {
    background-color: var(--base-color-brand--blue-light);
    color: var(--base-color-brand--blue-dark);
    border-color: var(--base-color-brand--blue-light);
  }
  .page-btn.active {
    background-color: var(--base-color-brand--blue-dark);
    color: var(--text-color--text-alternate);
    border-color: var(--base-color-brand--blue-dark);
    cursor: default;
  }
  .page-btn:disabled {
    opacity: 0.5;
    cursor: default;
  }
</style>

<script>
  // DOM Elements
  const container = document.querySelector(".article-list");
  if (container) {
    const radioButtons = document.querySelectorAll(".sort-by-radio");
    const keywordCloud = document.querySelector(".keyword-cloud");
    const bookmarkToggle = document.querySelector(".bookmarked-only");

    let activeKeyword = "all";
    let showBookmarkedOnly = false;
    let currentPage = 1;
    const itemsPerPage = 10;
    let currentMatchedItems = [];

    function renderPaginationControls(totalPages) {
      const topWrapper = document.querySelector(".top-pagination");
      const bottomWrapper = document.querySelector(".bottom-pagination");
      if (!topWrapper || !bottomWrapper) return;
      
      if (totalPages <= 1) {
        topWrapper.innerHTML = '';
        bottomWrapper.innerHTML = '';
        return;
      }

      const createControls = () => {
        const frag = document.createDocumentFragment();
        
        const prevBtn = document.createElement("button");
        prevBtn.className = "page-btn prev";
        prevBtn.textContent = "Prev";
        prevBtn.disabled = currentPage === 1;
        prevBtn.addEventListener("click", () => changePage(currentPage - 1));
        frag.appendChild(prevBtn);

        for (let i = 1; i <= totalPages; i++) {
          const pageBtn = document.createElement("button");
          pageBtn.className = `page-btn ${i === currentPage ? "active" : ""}`;
          pageBtn.textContent = i;
          pageBtn.addEventListener("click", () => changePage(i));
          frag.appendChild(pageBtn);
        }

        const nextBtn = document.createElement("button");
        nextBtn.className = "page-btn next";
        nextBtn.textContent = "Next";
        nextBtn.disabled = currentPage === totalPages;
        nextBtn.addEventListener("click", () => changePage(currentPage + 1));
        frag.appendChild(nextBtn);

        return frag;
      };

      topWrapper.innerHTML = '';
      topWrapper.appendChild(createControls());
      
      bottomWrapper.innerHTML = '';
      bottomWrapper.appendChild(createControls());
    }

    function changePage(newPage) {
      currentPage = newPage;
      updatePagination(currentMatchedItems);
      // scroll to top of list
      const targetElement = document.querySelector('.article-hero-lower');
      if (targetElement) {
         targetElement.scrollIntoView({ behavior: 'smooth' });
      }
    }

    function updatePagination(matchedItems) {
      currentMatchedItems = matchedItems;
      const totalPages = Math.ceil(matchedItems.length / itemsPerPage);
      
      if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      renderPaginationControls(totalPages);

      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;

      matchedItems.forEach((item, index) => {
        if (index >= startIndex && index < endIndex) {
          item.style.display = "";
        } else {
          item.style.display = "none";
        }
      });
    }

    // Filter Function
    function applyFilters() {
      const items = Array.from(container.querySelectorAll(".article-row"));
      const bookmarkedSlugs = JSON.parse(
        localStorage.getItem("bookmarked_posts") || "[]",
      );
      const noBookmarkMsg = document.querySelector(
        ".no-bookmark-filter-msg",
      ) as HTMLElement | null;

      const matchedItems = [];

      items.forEach((item) => {
        const itemKeywords = item.getAttribute("data-keywords") || "";
        const itemSlug = item.getAttribute("data-slug") || "";

        const keywordsArray = itemKeywords
          .split(",")
          .map((k) => k.trim().toLowerCase())
          .filter(Boolean);
        const matchesKeyword =
          activeKeyword === "all" ||
          keywordsArray.includes(activeKeyword.toLowerCase());
        const matchesBookmark =
          !showBookmarkedOnly || bookmarkedSlugs.includes(itemSlug);

        if (matchesKeyword && matchesBookmark) {
          matchedItems.push(item);
        } else {
          (item as HTMLElement).style.display = "none";
        }
      });

      if (noBookmarkMsg) {
        noBookmarkMsg.style.display =
          showBookmarkedOnly && matchedItems.length === 0 ? "block" : "none";
      }

      updatePagination(matchedItems);
    }

    // 1. Sort Handling
    radioButtons.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        if (e) e.preventDefault();

        const sortType = btn.getAttribute("data-sort-type");
        const storageKey = `sort_pref_${window.location.pathname}`;
        if (sortType) {
          localStorage.setItem(storageKey, sortType);
        }

        radioButtons.forEach((b) => {
          b.setAttribute("data-active", b === btn ? "true" : "false");
          const textBlock = b.querySelector(".text-block-8, .text-block-9");
          if (textBlock) {
            textBlock.className = b === btn ? "text-block-8" : "text-block-9";
          }
        });

        const isCaseCategory =
          container!.getAttribute("data-is-case-category") === "true";
        const items = Array.from(container!.querySelectorAll(".article-row"));

        items.sort((a, b) => {
          if (sortType === "latest") {
            if (isCaseCategory) {
              const yearA = parseInt(
                a.getAttribute("data-citation-year") || "0",
                10,
              );
              const yearB = parseInt(
                b.getAttribute("data-citation-year") || "0",
                10,
              );
              if (yearB !== yearA) {
                return yearB - yearA;
              }
              const titleA = a.getAttribute("data-title") || "";
              const titleB = b.getAttribute("data-title") || "";
              return titleA.localeCompare(titleB);
            } else {
              const valA = parseInt(a.getAttribute("data-pubdate") || "0", 10);
              const valB = parseInt(b.getAttribute("data-pubdate") || "0", 10);
              return valB - valA;
            }
          } else if (sortType === "oldest") {
            if (isCaseCategory) {
              const yearA = parseInt(
                a.getAttribute("data-citation-year") || "0",
                10,
              );
              const yearB = parseInt(
                b.getAttribute("data-citation-year") || "0",
                10,
              );
              if (yearA !== yearB) {
                return yearA - yearB;
              }
              const titleA = a.getAttribute("data-title") || "";
              const titleB = b.getAttribute("data-title") || "";
              return titleA.localeCompare(titleB);
            } else {
              const valA = parseInt(a.getAttribute("data-pubdate") || "0", 10);
              const valB = parseInt(b.getAttribute("data-pubdate") || "0", 10);
              return valA - valB;
            }
          } else if (sortType === "recently-added") {
            const valA = parseInt(a.getAttribute("data-created") || "0", 10);
            const valB = parseInt(b.getAttribute("data-created") || "0", 10);
            return valB - valA;
          } else if (sortType === "most-popular") {
            const valA = parseInt(a.getAttribute("data-views") || "0", 10);
            const valB = parseInt(b.getAttribute("data-views") || "0", 10);
            return valB - valA;
          } else if (sortType === "alphabetical") {
            const valA = a.getAttribute("data-title") || "";
            const valB = b.getAttribute("data-title") || "";
            return valA.localeCompare(valB);
          }
          return 0;
        });

        items.forEach((item) => container!.appendChild(item));
        currentPage = 1;
        applyFilters();
      });
    });

    // 2. Keyword Filter Handling
    if (keywordCloud) {
      const keywordTags = keywordCloud.querySelectorAll(
        ".keyword-tag, .keyword-link",
      );

      keywordTags.forEach((tag) => {
        tag.addEventListener("click", (e) => {
          e.preventDefault();

          let rawKeyword = tag.textContent || "";
          const cleanKeyword = rawKeyword.trim();

          if (cleanKeyword === "All" || cleanKeyword === "전체") {
            activeKeyword = "all";
          } else {
            activeKeyword = cleanKeyword;
          }

          keywordCloud.querySelectorAll(".keyword-tag").forEach((t) => {
            const isAllTag = t.classList.contains("all");
            const tText = t.textContent?.trim() || "";

            if (activeKeyword === "all") {
              if (isAllTag) {
                t.setAttribute("data-active", "true");
              } else {
                t.removeAttribute("data-active");
              }
            } else {
              if (tText.toLowerCase() === activeKeyword.toLowerCase()) {
                t.setAttribute("data-active", "true");
              } else {
                t.removeAttribute("data-active");
              }
            }
          });

          currentPage = 1;
          applyFilters();
        });
      });

      const allTag = keywordCloud.querySelector(".keyword-tag.all");
      if (allTag) {
        allTag.setAttribute("data-active", "true");
      }
    }

    // 3. Bookmark Filter Handling
    if (bookmarkToggle) {
      bookmarkToggle.addEventListener("click", (e) => {
        e.preventDefault();

        showBookmarkedOnly = !showBookmarkedOnly;
        bookmarkToggle.setAttribute(
          "data-active",
          showBookmarkedOnly ? "true" : "false",
        );

        currentPage = 1;
        applyFilters();
      });
    }

    // Sync filters on page load/bookmark updates
    window.addEventListener("bookmark-updated", () => {
      currentPage = 1;
      applyFilters();
    });
    // Restore sort preference on load
    const storageKey = `sort_pref_${window.location.pathname}`;
    const savedSort = localStorage.getItem(storageKey);
    let sortRestored = false;
    
    if (savedSort) {
      const savedBtn = Array.from(radioButtons).find(b => b.getAttribute("data-sort-type") === savedSort);
      if (savedBtn && savedBtn.getAttribute("data-active") !== "true") {
        savedBtn.dispatchEvent(new Event("click"));
        sortRestored = true;
      }
    }
    
    if (!sortRestored) {
      applyFilters();
    }
  }
</script>
