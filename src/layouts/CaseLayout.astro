---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { Lang } from '../utils/i18n';
import AdSlot from '../components/AdSlot.astro';

interface Props {
  lang: Lang;
  slug: string;
  category: string;
  title: string;       // clean H1 title, e.g. "Williams v Carwardine"
  seoTitle?: string;   // SEO browser tab title, e.g. "Williams v Carwardine (1833) | Unilateral Contracts"
  description: string;
  citation?: string;
  court?: string;
  claimantRole?: string;
  claimant?: string;
  defendantRole?: string;
  defendant?: string;
  courtLink?: string;
  pubDate: Date;
  modifiedDate?: Date;
  uiTags?: string[];
}

const {
  lang,
  slug,
  category,
  title,
  seoTitle,
  description,
  citation,
  court,
  claimantRole,
  claimant,
  defendantRole,
  defendant,
  courtLink,
  pubDate,
  modifiedDate,
  uiTags,
} = Astro.props;

const currentTags = uiTags || [];

// Fetch related cases in the same category and language
const relatedCases = await getCollection('posts', ({ data }) => {
  return data.lang === lang && data.category === category && data.slug !== slug && !data.draft;
});

// Calculate matching tags and shuffle
const relatedWithScore = relatedCases.map(post => {
  const postTags = post.data.uiTags || [];
  const matchCount = postTags.filter((tag: string) => currentTags.includes(tag)).length;
  const randomScore = Math.random();
  return { post, matchCount, randomScore };
});

relatedWithScore.sort((a, b) => {
  if (a.matchCount !== b.matchCount) {
    return b.matchCount - a.matchCount;
  }
  return b.randomScore - a.randomScore;
});

const slicedRelated = relatedWithScore.slice(0, 3).map(item => item.post);

function formatDate(date: Date, locale: string) {
  return date.toLocaleDateString(locale === 'ko' ? 'ko-KR' : 'en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}
---
<BaseLayout
  lang={lang}
  title={`${seoTitle || title} · YoungkukLaw`}
  description={description}
  type="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={modifiedDate ? modifiedDate.toISOString() : undefined}
>
  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="article-hero-container">
          <div class="article-hero-upper">
            <h1 class="heading-style-h1">{title}</h1>
          </div>
          <div class="spacer-medium"></div>
          <div class="hr-div"></div>
          <div class="spacer-xsmall"></div>
          <div class="article-hero-lower-left">
            {citation && (
              <div class="article-hero-column">
                <div class="column-label">Citation</div>
                {courtLink ? (
                  <a href={courtLink} target="_blank" rel="noopener noreferrer" class="link-block-generic w-inline-block">
                    <div class="column-text">{citation}</div>
                  </a>
                ) : (
                  <div class="column-text">{citation}</div>
                )}
              </div>
            )}
            {court && (
              <>
                <div class="vr-div"></div>
                <div class="article-hero-column">
                  <div class="column-label">Court</div>
                  <div class="column-text">{court}</div>
                </div>
              </>
            )}
            {claimant && (
              <>
                <div class="vr-div"></div>
                <div class="article-hero-column">
                  <div class="column-label">{claimantRole || 'Claimant'}</div>
                  <div class="column-text">{claimant}</div>
                </div>
              </>
            )}
            {defendant && (
              <>
                <div class="vr-div"></div>
                <div class="article-hero-column">
                  <div class="column-label">{defendantRole || 'Defendant'}</div>
                  <div class="column-text">{defendant}</div>
                </div>
              </>
            )}
          </div>
          <div class="spacer-medium"></div>
          <div class="article-hero-lower">
            <div class="article-hero-lower-left">
              <div class="article-hero-column">
                <div class="column-label">Views</div>
                <div class="view-number">
                  <div class="eye-icon w-embed">
                    <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
                      <path d="M607.5-372.5Q660-425 660-500t-52.5-127.5Q555-680 480-680t-127.5 52.5Q300-575 300-500t52.5 127.5Q405-320 480-320t127.5-52.5Zm-204-51Q372-455 372-500t31.5-76.5Q435-608 480-608t76.5 31.5Q588-545 588-500t-31.5 76.5Q525-392 480-392t-76.5-31.5ZM214-281.5Q94-363 40-500q54-137 174-218.5T480-800q146 0 266 81.5T920-500q-54 137-174 218.5T480-200q-146 0-266-81.5ZM480-500Zm207.5 160.5Q782-399 832-500q-50-101-144.5-160.5T480-720q-113 0-207.5 59.5T128-500q50 101 144.5 160.5T480-280q113 0 207.5-59.5Z"></path>
                    </svg>
                  </div>
                  <div class="view-number-num" id="view-counter" data-slug={slug}>0</div>
                </div>
              </div>
              <div class="vr-div"></div>
              <div class="article-hero-column">
                <div class="column-label">Updated on YoungkukLaw</div>
                <div class="column-text">{formatDate(pubDate, lang)}</div>
              </div>
            </div>
            <div class="article-hero-lower-right">
              <a href="#" class="bookmark-btn w-inline-block" data-slug={slug}>
                <div class="bookmark-btn-off w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
                    <path d="M200-120v-640q0-33 23.5-56.5T280-840h400q33 0 56.5 23.5T760-760v640L480-240 200-120Zm80-122 200-86 200 86v-518H280v518Zm0-518h400-400Z"></path>
                  </svg>
                </div>
                <div class="bookmark-btn-on w-embed">
                  <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="7" y="5" width="10" height="13" fill="#FFC400"></rect>
                    <path d="M5 21V5C5 4.45 5.19583 3.97917 5.5875 3.5875C5.97917 3.19583 6.45 3 7 3H17C17.55 3 18.0208 3.19583 18.4125 3.5875C18.8042 3.97917 19 4.45 19 5V21L12 18L5 21ZM7 17.95L12 15.8L17 17.95V5H7V17.95Z" fill="currentColor"></path>
                  </svg>
                </div>
                <div class="bookmarked-only-label">Bookmark</div>
              </a>

              <a href="#" class="print-button w-inline-block" onclick="window.print(); return false;">
                <div class="print-icon w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
                    <path d="M640-640v-120H320v120h-80v-200h480v200h-80Zm-480 80h640-640Zm560 100q17 0 28.5-11.5T760-500q0-17-11.5-28.5T720-540q-17 0-28.5 11.5T680-500q0 17 11.5 28.5T720-460Zm-80 260v-160H320v160h320Zm80 80H240v-160H80v-240q0-51 35-85.5t85-34.5h560q51 0 85.5 34.5T880-520v240H720v160Zm80-240v-160q0-17-11.5-28.5T760-560H200q-17 0-28.5 11.5T160-520v160h80v-80h480v80h80Z"></path>
                  </svg>
                </div>
              </a>
              <a href="#" class="link-block-2 share-button w-inline-block">
                <div class="share-icon w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
                    <path d="M680-80q-50 0-85-35t-35-85q0-6 3-28L282-392q-16 15-37 23.5t-45 8.5q-50 0-85-35t-35-85q0-50 35-85t85-35q24 0 45 8.5t37 23.5l281-164q-2-7-2.5-13.5T560-760q0-50 35-85t85-35q50 0 85 35t35 85q0 50-35 85t-85 35q-24 0-45-8.5T598-672L317-508q2 7 2.5 13.5t.5 14.5q0 8-.5 14.5T317-452l281 164q16-15 37-23.5t45-8.5q50 0 85 35t35 85q0 50-35 85t-85 35Zm0-80q17 0 28.5-11.5T720-200q0-17-11.5-28.5T680-240q-17 0-28.5 11.5T640-200q0 17 11.5 28.5T680-160ZM200-440q17 0 28.5-11.5T240-480q0-17-11.5-28.5T200-520q-17 0-28.5 11.5T160-480q0 17 11.5 28.5T200-440Zm508.5-291.5Q720-743 720-760t-11.5-28.5Q697-800 680-800t-28.5 11.5Q640-777 640-760t11.5 28.5Q663-720 680-720t28.5-11.5ZM680-200ZM200-480Zm480-280Z"></path>
                  </svg>
                </div>
              </a>
            </div>
          </div>
          <div class="spacer-xsmall"></div>
          <div class="hr-div"></div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="article-block">
          <div class="article-body">
            <div class="article-text">
              <AdSlot slot="post-top-ad" />
              <div class="spacer-small"></div>
              <slot />
            </div>
            
            <div class="article-hero-lower-right article-post-bottom-actions">
              <a href="#" class="bookmark-btn w-inline-block" data-slug={slug}>
                <div class="bookmark-btn-off w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
                    <path d="M200-120v-640q0-33 23.5-56.5T280-840h400q33 0 56.5 23.5T760-760v640L480-240 200-120Zm80-122 200-86 200 86v-518H280v518Zm0-518h400-400Z"></path>
                  </svg>
                </div>
                <div class="bookmark-btn-on w-embed">
                  <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="7" y="5" width="10" height="13" fill="#FFC400"></rect>
                    <path d="M5 21V5C5 4.45 5.19583 3.97917 5.5875 3.5875C5.97917 3.19583 6.45 3 7 3H17C17.55 3 18.0208 3.19583 18.4125 3.5875C18.8042 3.97917 19 4.45 19 5V21L12 18L5 21ZM7 17.95L12 15.8L17 17.95V5H7V17.95Z" fill="currentColor"></path>
                  </svg>
                </div>
                <div class="bookmarked-only-label">Bookmark</div>
              </a>

              <a href="#" class="print-button w-inline-block" onclick="window.print(); return false;">
                <div class="print-icon w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
                    <path d="M640-640v-120H320v120h-80v-200h480v200h-80Zm-480 80h640-640Zm560 100q17 0 28.5-11.5T760-500q0-17-11.5-28.5T720-540q-17 0-28.5 11.5T680-500q0 17 11.5 28.5T720-460Zm-80 260v-160H320v160h320Zm80 80H240v-160H80v-240q0-51 35-85.5t85-34.5h560q51 0 85.5 34.5T880-520v240H720v160Zm80-240v-160q0-17-11.5-28.5T760-560H200q-17 0-28.5 11.5T160-520v160h80v-80h480v80h80Z"></path>
                  </svg>
                </div>
              </a>
              <a href="#" class="link-block-2 share-button w-inline-block">
                <div class="share-icon w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
                    <path d="M680-80q-50 0-85-35t-35-85q0-6 3-28L282-392q-16 15-37 23.5t-45 8.5q-50 0-85-35t-35-85q0-50 35-85t85-35q24 0 45 8.5t37 23.5l281-164q-2-7-2.5-13.5T560-760q0-50 35-85t85-35q50 0 85 35t35 85q0 50-35 85t-85 35q-24 0-45-8.5T598-672L317-508q2 7 2.5 13.5t.5 14.5q0 8-.5 14.5T317-452l281 164q16-15 37-23.5t45-8.5q50 0 85 35t35 85q0 50-35 85t-85 35Zm0-80q17 0 28.5-11.5T720-200q0-17-11.5-28.5T680-240q-17 0-28.5 11.5T640-200q0 17 11.5 28.5T680-160ZM200-440q17 0 28.5-11.5T240-480q0-17-11.5-28.5T200-520q-17 0-28.5 11.5T160-480q0 17 11.5 28.5T200-440Zm508.5-291.5Q720-743 720-760t-11.5-28.5Q697-800 680-800t-28.5 11.5Q640-777 640-760t11.5 28.5Q663-720 680-720t28.5-11.5ZM680-200ZM200-480Zm480-280Z"></path>
                  </svg>
                </div>
              </a>
            </div>
            
            <div class="google-adsense-placeholder">

              <AdSlot slot="post-content-right-ad" />
            </div>
          </div>
          
          {/* Right Sidebar - Relevant Cases */}
          <div class="article-right">
            <div class="relevant-articles">
              <div class="sort-by-upper">
                <div class="article-list-left-heading">{lang === 'en' ? 'Relevant Cases' : '관련 판례'}</div>
              </div>
              <div class="relevant-articles-grid">
                {slicedRelated.map(related => (
                  <div class="case-card">
                    <div class="case-card-upper">
                      {related.data.uiTags && related.data.uiTags.length > 0 ? (
                        <div class="tags-container" style="display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 8px;">
                          {related.data.uiTags.map((tag: string) => (
                            <div class="subject-tag">{tag}</div>
                          ))}
                        </div>
                      ) : (
                        <div class="subject-tag">{lang === 'en' ? 'Case' : '판례'}</div>
                      )}
                      <a href={lang === 'en' ? `/${related.data.slug}/` : `/ko/${related.data.slug}/`} class="link-block w-inline-block">
                        <div class="heading-style-h4">{related.data.title}</div>
                        {related.data.citation && (
                          <div class="case-citation-text">{related.data.citation}</div>
                        )}
                      </a>
                    </div>
                    <div class="hr-div"></div>
                    <div class="note-row-right">
                      <div class="featured-content-desc">{related.data.uiDescription || related.data.description}</div>
                      <div class="spacer-small"></div>
                      <a href={lang === 'en' ? `/${related.data.slug}/` : `/ko/${related.data.slug}/`} class="btn-read-more w-inline-block">
                        <div class="featured-content-desc">{lang === 'en' ? 'Read More' : '자세히 보기'}</div>
                      </a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            
            <div class="google-adsense-placeholder">
              <AdSlot slot="post-sidebar-ad-1" />
            </div>
            <div class="google-adsense-placeholder">
              <AdSlot slot="post-sidebar-ad-2" />
            </div>
          </div>
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Share Button Action
  const shareButtons = document.querySelectorAll('.share-button');
  shareButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const url = window.location.href;
      
      if (navigator.share) {
        navigator.share({
          title: document.title,
          url: url
        }).catch(err => console.log('Error sharing:', err));
      } else {
        navigator.clipboard.writeText(url).then(() => {
          alert('Link copied to clipboard!');
        }).catch(err => {
          console.error('Could not copy text: ', err);
        });
      }
    });
  });
</script>

