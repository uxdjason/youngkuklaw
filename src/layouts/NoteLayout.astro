---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { Lang } from '../utils/i18n';
import { CATEGORY_LABELS } from '../utils/i18n';
import AdSlot from '../components/AdSlot.astro';

interface Props {
  lang: Lang;
  slug: string;
  category: string;
  title: string;
  description: string;
  pubDate: Date;
}

const {
  lang,
  slug,
  category,
  title,
  description,
  pubDate,
} = Astro.props;

// Fetch related notes in the same category and language
const relatedNotes = await getCollection('posts', ({ data }) => {
  return data.lang === lang && data.category === category && data.slug !== slug && !data.draft;
});
const slicedRelated = relatedNotes.slice(0, 3);

const categoryLabel = CATEGORY_LABELS[category]?.[lang] || category;

function formatDate(date: Date, locale: string) {
  return date.toLocaleDateString(locale === 'ko' ? 'ko-KR' : 'en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}
---
<BaseLayout
  lang={lang}
  title={`${title} · YoungkukLaw`}
  description={description}
  type="article"
  publishedTime={pubDate.toISOString()}
>
  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="article-hero-container">
          <div class="article-hero-upper">
            <h1 class="heading-style-h1">{title}</h1>
          </div>
          <div class="spacer-medium"></div>
          <div class="hr-div"></div>
          <div class="spacer-xsmall"></div>
          <div class="article-hero-lower">
            <div class="article-hero-lower-left">
              <div class="article-hero-column">
                <div class="column-label">{lang === 'en' ? 'Category' : '과목'}</div>
                <a href={lang === 'en' ? `/${category}/` : `/ko/${category}/`} class="link-block-generic w-inline-block">
                  <div class="column-text">{categoryLabel}</div>
                </a>
              </div>
              <div class="vr-div"></div>
              <div class="article-hero-column">
                <div class="column-label">Views</div>
                <div class="view-number">
                  <div class="eye-icon w-embed">
                    <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
                      <path d="M607.5-372.5Q660-425 660-500t-52.5-127.5Q555-680 480-680t-127.5 52.5Q300-575 300-500t52.5 127.5Q405-320 480-320t127.5-52.5Zm-204-51Q372-455 372-500t31.5-76.5Q435-608 480-608t76.5 31.5Q588-545 588-500t-31.5 76.5Q525-392 480-392t-76.5-31.5ZM214-281.5Q94-363 40-500q54-137 174-218.5T480-800q146 0 266 81.5T920-500q-54 137-174 218.5T480-200q-146 0-266-81.5ZM480-500Zm207.5 160.5Q782-399 832-500q-50-101-144.5-160.5T480-720q-113 0-207.5 59.5T128-500q50 101 144.5 160.5T480-280q113 0 207.5-59.5Z"></path>
                    </svg>
                  </div>
                  <div class="view-number-num">940</div>
                </div>
              </div>
              <div class="vr-div"></div>
              <div class="article-hero-column">
                <div class="column-label">Updated</div>
                <div class="column-text">{formatDate(pubDate, lang)}</div>
              </div>
            </div>
            <div class="article-hero-lower-right">
              <a href="#" class="bookmark-btn w-inline-block" data-slug={slug}>
                <div class="bookmark-btn-off w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
                    <path d="M200-120v-640q0-33 23.5-56.5T280-840h400q33 0 56.5 23.5T760-760v640L480-240 200-120Zm80-122 200-86 200 86v-518H280v518Zm0-518h400-400Z"></path>
                  </svg>
                </div>
                <div class="bookmarked-only-label">Bookmark</div>
              </a>
              <a href="#" class="print-button w-inline-block" onclick="window.print(); return false;">
                <div class="print-icon w-embed">
                  <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
                    <path d="M640-640v-120H320v120h-80v-200h480v200h-80Zm-480 80h640-640Zm560 100q17 0 28.5-11.5T760-500q0-17-11.5-28.5T720-540q-17 0-28.5 11.5T680-500q0 17 11.5 28.5T720-460Zm-80 260v-160H320v160h320Zm80 80H240v-160H80v-240q0-51 35-85.5t85-34.5h560q51 0 85.5 34.5T880-520v240H720v160Zm80-240v-160q0-17-11.5-28.5T760-560H200q-17 0-28.5 11.5T160-520v160h80v-80h480v80h80Z"></path>
                  </svg>
                </div>
              </a>
            </div>
          </div>
          <div class="spacer-xsmall"></div>
          <div class="hr-div"></div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="article-block">
          <div class="article-body">
            <div class="article-text">
              <AdSlot slot="post-top-ad" />
              <div class="spacer-small"></div>
              <slot />
              <div class="spacer-small"></div>
              <AdSlot slot="post-bottom-ad" />
            </div>
            <div class="google-adsense-placeholder">
              <AdSlot slot="post-content-right-ad" />
            </div>
          </div>
          
          {/* Right Sidebar - Relevant Articles */}
          <div class="article-right">
            <div class="relevant-articles">
              <div class="sort-by-upper">
                <div class="article-list-left-heading">{lang === 'en' ? 'Relevant Articles' : '관련 강의 노트'}</div>
              </div>
              <div class="relevant-articles-grid">
                {slicedRelated.map(related => (
                  <div class="case-card">
                    <div class="case-card-upper">
                      <div class="subject-tag">{lang === 'en' ? 'Note' : '노트'}</div>
                      <a href={lang === 'en' ? `/${related.data.slug}/` : `/ko/${related.data.slug}/`} class="link-block w-inline-block">
                        <div class="heading-style-h4">{related.data.title}</div>
                      </a>
                    </div>
                    <div class="hr-div"></div>
                    <div class="note-row-right">
                      <div class="featured-content-desc">{related.data.description}</div>
                      <div class="spacer-small"></div>
                      <a href={lang === 'en' ? `/${related.data.slug}/` : `/ko/${related.data.slug}/`} class="btn-read-more w-inline-block">
                        <div class="featured-content-desc">{lang === 'en' ? 'Read More' : '자세히 보기'}</div>
                      </a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            
            <div class="google-adsense-placeholder">
              <AdSlot slot="post-sidebar-ad-1" />
            </div>
            <div class="google-adsense-placeholder">
              <AdSlot slot="post-sidebar-ad-2" />
            </div>
          </div>
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>
</BaseLayout>
