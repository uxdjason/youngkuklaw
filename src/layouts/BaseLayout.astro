---
import "../styles/normalize.css";
import "../styles/webflow.css";
import "../styles/fonts.css";
import "../styles/youngkuklaw.webflow.css";

import type { Lang } from "../utils/i18n";
import SEO from "../components/SEO.astro";
import AdblockGuard from "../components/AdblockGuard.astro";
import HeaderEn from "../components/header/HeaderEn.astro";
import HeaderKo from "../components/header/HeaderKo.astro";
import FooterEn from "../components/footer/FooterEn.astro";
import FooterKo from "../components/footer/FooterKo.astro";

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  noindex?: boolean;
}

const {
  lang,
  title,
  description,
  image,
  type = "website",
  publishedTime,
  modifiedTime,
  breadcrumbs,
  noindex,
} = Astro.props;

const htmlLang = lang === "ko" ? "ko-KR" : "en-GB";
const bodyClass = lang === "ko" ? "body ko" : "body";

const FONT_PRELOADS =
  lang === "ko"
    ? [
        { href: "/fonts/NanumMyeongjo-Regular.woff2", type: "font/woff2" },
        { href: "/fonts/NanumGothic-Regular.woff2", type: "font/woff2" },
      ]
    : [
        { href: "/fonts/Playfair-Regular.woff2", type: "font/woff2" },
        { href: "/fonts/Inter-Regular.woff2", type: "font/woff2" },
      ];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    {
      FONT_PRELOADS.map((f) => (
        <link
          rel="preload"
          as="font"
          type={f.type}
          href={f.href}
          crossorigin="anonymous"
        />
      ))
    }

    <link
      rel="icon"
      href="/images/favicon.png"
      type="image/png"
      sizes="32x32"
    />
    <link rel="apple-touch-icon" href="/images/webclip.png" sizes="180x180" />

    <SEO
      lang={lang}
      title={title}
      description={description}
      image={image}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      breadcrumbs={breadcrumbs}
      noindex={noindex}
    />

    <script is:inline>
      // Webflow expects "w-mod-js" / "w-mod-touch" classes for some interactions.
      (function (o, c) {
        var n = c.documentElement;
        var t = " w-mod-";
        n.className += t + "js";
        if (
          "ontouchstart" in o ||
          (o.DocumentTouch && c instanceof DocumentTouch)
        ) {
          n.className += t + "touch";
        }
      })(window, document);
    </script>
  </head>
  <body class={bodyClass}>
    <AdblockGuard lang={lang} />
    {lang === "ko" ? <HeaderKo /> : <HeaderEn />}

    <main>
      <slot />
    </main>

    <div class="print-only-footer">
      <div class="print-footer-brand">
        {lang === "ko" ? (
          <div style="display: flex; align-items: center; gap: 8px; justify-content: center;">
            <img src="/images/youngkuklaw-logo-260519.png" alt="영국 Law Logo" style="width: 40px; height: 40px; object-fit: contain;" />
            <div class="text-block-11">영국 Law</div>
          </div>
        ) : (
          <div style="display: flex; align-items: center; gap: 8px; justify-content: center;">
            <img src="/images/youngkuklaw-logo-260519.png" alt="YoungkukLaw Logo" style="width: 40px; height: 40px; object-fit: contain;" />
            <div class="text-block-11">YoungkukLaw</div>
          </div>
        )}
      </div>
      <div class="print-footer-url-wrapper">
        <a class="print-footer-url" id="print-url" href="" target="_blank" rel="noopener"></a>
      </div>
    </div>

    {lang === "ko" ? <FooterKo /> : <FooterEn />}

    {
      /* jQuery + webflow.js — required by the ported Webflow markup
       (nav dropdown, mobile burger). Static, self-hosted. */
    }
    <script
      src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js"
      integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
      crossorigin="anonymous"
      is:inline></script>
    <script src="/js/webflow.js" is:inline></script>

    <script>
      // Global Bookmark Syncing
      const updateUI = () => {
        const bookmarkedSlugs = JSON.parse(
          localStorage.getItem("bookmarked_posts") || "[]",
        );

        document.querySelectorAll(".bookmark, .bookmark-btn").forEach((btn) => {
          const slug = btn.getAttribute("data-slug");
          if (slug) {
            const isBookmarked = bookmarkedSlugs.includes(slug);
            if (isBookmarked) {
              btn.setAttribute("data-bookmarked", "true");
            } else {
              btn.removeAttribute("data-bookmarked");
            }
          }
        });
      };

      const initBookmarks = () => {
        updateUI();

        // Populate print URL
        const printUrlEl = document.getElementById("print-url");
        if (printUrlEl) {
          const url = window.location.href;
          printUrlEl.textContent = url;
          (printUrlEl as HTMLAnchorElement).href = url;
        }

        // Bind clicks
        document.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest(
            ".bookmark, .bookmark-btn",
          );
          if (!btn) return;

          e.preventDefault();
          const slug = btn.getAttribute("data-slug");
          if (!slug) return;

          let slugs = JSON.parse(
            localStorage.getItem("bookmarked_posts") || "[]",
          );
          let dates: Record<string, string> = JSON.parse(
            localStorage.getItem("bookmark_dates") || "{}",
          );
          if (slugs.includes(slug)) {
            slugs = slugs.filter((s: string) => s !== slug);
            delete dates[slug];
          } else {
            slugs.push(slug);
            dates[slug] = new Date().toISOString();
          }

          localStorage.setItem("bookmarked_posts", JSON.stringify(slugs));
          localStorage.setItem("bookmark_dates", JSON.stringify(dates));
          updateUI();

          // Dispatch event to notify other pages/components
          window.dispatchEvent(new Event("bookmark-updated"));
        });

        // Keep state in sync across different components
        window.addEventListener("bookmark-updated", updateUI);
      };

      const initViewCounter = async () => {
        // Use localhost API if local, else use the deployed worker
        const isLocalhost =
          window.location.hostname === "localhost" ||
          window.location.hostname === "127.0.0.1";
        const API_BASE = isLocalhost
          ? "http://localhost:8787"
          : "https://youngkuklaw-views.uxd-jason.workers.dev"; // User needs to replace USERNAME

        // Find the single post view counter (which increments)
        const singleCounter = document.getElementById("view-counter");
        if (singleCounter) {
          const slug = singleCounter.getAttribute("data-slug");
          if (slug) {
            try {
              const res = await fetch(`${API_BASE}/api/views/${slug}`, {
                method: "POST",
              });
              if (res.ok) {
                const data = await res.json();
                singleCounter.textContent = data.views;
              }
            } catch (e) {
              console.error("Failed to increment views", e);
            }
          }
        }

        // Find all batch view counters (on list pages)
        const batchCounters = document.querySelectorAll(".view-counter-batch");
        if (batchCounters.length > 0) {
          const slugs = Array.from(batchCounters)
            .map((el) => el.getAttribute("data-slug"))
            .filter(Boolean);
          const uniqueSlugs = [...new Set(slugs)];
          if (uniqueSlugs.length > 0) {
            try {
              const res = await fetch(
                `${API_BASE}/api/views?slugs=${uniqueSlugs.join(",")}`,
              );
              if (res.ok) {
                const data = await res.json();
                batchCounters.forEach((el) => {
                  const slug = el.getAttribute("data-slug");
                  if (slug && data[slug] !== undefined) {
                    const originalText = el.textContent || "";
                    if (originalText.includes("views")) {
                      el.textContent = `${data[slug]} views`;
                    } else {
                      el.textContent = data[slug];
                    }
                    const row = el.closest(".article-row");
                    if (row) {
                      row.setAttribute("data-views", data[slug]);
                    }
                  }
                });
              }
            } catch (e) {
              console.error("Failed to fetch batch views", e);
            }
          }
        }
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () => {
          initBookmarks();
          initViewCounter();
        });
      } else {
        initBookmarks();
        initViewCounter();
      }
    </script>
  </body>
</html>
