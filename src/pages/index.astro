---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS } from '../utils/i18n';
import SearchBar from '../components/SearchBar.astro';

const lang = 'en';

// Featured: 3 cases
const featuredCases = await getCollection('posts', ({ data }) => {
  return data.lang === lang && data.category.endsWith('-cases') && !data.draft;
});
const slicedFeatured = featuredCases
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Latest Notes: 12 notes
const latestNotes = await getCollection('posts', ({ data }) => {
  return data.lang === lang && !data.category.endsWith('-cases') && !data.draft;
});
const sortedNotes = latestNotes
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}
---
<BaseLayout
  lang={lang}
  title="YoungkukLaw — Study English Law, Clear Notes, Real Cases, Free"
  description="Quality lecture notes and a vast database of cases for law students worldwide. Study English contract, tort, public, criminal, equity and land law for free."
>
  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h1 align-center">Study English Law -<br />Clear Notes, Real Cases, Free.</div>
        <div class="spacer-small"></div>
        <div class="text-size-medium align-center">Quality lecture notes and a vast database of cases for law students worldwide.</div>
        <div class="spacer-large"></div>
        <SearchBar lang={lang} />
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h2">Featured Case Law</div>
        <div class="spacer-small"></div>
        <div class="case-grid">
          {slicedFeatured.length === 0 ? (
            <div class="case-card">
              <div class="featured-content-desc">No featured cases available yet.</div>
            </div>
          ) : (
            slicedFeatured.map(post => (
              <div class="case-card">
                <div class="case-card-upper">
                  <div class="subject-tag">{CATEGORY_LABELS[post.data.category]?.en || 'Case'}</div>
                  <a href={`/${post.data.slug}/`} class="link-block w-inline-block">
                    <div class="heading-style-h4">{post.data.title}</div>
                    {post.data.citation && <div class="case-citation-text">{post.data.citation}</div>}
                  </a>
                </div>
                <div class="hr-div"></div>
                <div class="note-row-right">
                  <div class="featured-content-desc">{post.data.description}</div>
                  <div class="spacer-small"></div>
                  <a href={`/${post.data.slug}/`} class="btn-read-more w-inline-block">
                    <div class="featured-content-desc">Read More</div>
                  </a>
                </div>
              </div>
            ))
          )}
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>

  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h2">Latest Notes</div>
        <div class="spacer-small"></div>
        <div class="note-container">
          {sortedNotes.length === 0 ? (
            <div class="note-row">
              <div class="featured-content-desc">No notes available yet.</div>
            </div>
          ) : (
            sortedNotes.map((post, index) => (
              <>
                <div class="note-row">
                  <div class="note-row-left">
                    <div class="subject-tag">{CATEGORY_LABELS[post.data.category]?.en || 'Note'}</div>
                    <a href={`/${post.data.slug}/`} class="link-block w-inline-block">
                      <div class="featured-content-desc">{post.data.title}</div>
                    </a>
                  </div>
                  <div class="note-row-right">
                    <div class="note-row-timestamp">{formatDate(post.data.pubDate)}</div>
                  </div>
                </div>
                {index < sortedNotes.length - 1 && <div class="hr-div no-margin"></div>}
              </>
            ))
          )}
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>
</BaseLayout>
