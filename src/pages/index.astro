---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  lang="en"
  title="YoungkukLaw — Study English Law, Clear Notes, Real Cases, Free"
  description="Quality lecture notes and a vast database of cases for law students worldwide. Study English contract, tort, public, criminal, equity and land law for free."
>
  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h1 align-center">Study English Law -<br />Clear Notes, Real Cases, Free.</div>
        <div class="spacer-small"></div>
        <div class="text-size-medium align-center">Quality lecture notes and a vast database of cases for law students worldwide.</div>
        <div class="spacer-large"></div>
        <div class="search-bar">
          <div class="search-placeholder-text">Search...</div>
          <div class="code-embed w-embed">
            <svg xmlns="http://www.w3.org/2000/svg" height="1em" viewBox="0 -960 960 960" width="1em" fill="currentColor">
              <path d="M784-120 532-372q-30 24-69 38t-83 14q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l252 252-56 56ZM380-400q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z"></path>
            </svg>
          </div>
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h2">Featured Case Law</div>
        <div class="spacer-small"></div>
        <div class="case-grid">
          <div class="case-card">
            <div class="case-card-upper">
              <div class="subject-tag">Contract</div>
              <a href="/sample-test/" class="link-block w-inline-block">
                <div class="heading-style-h4">Sample Case Card</div>
                <div class="case-citation-text">[Placeholder citation]</div>
              </a>
            </div>
            <div class="hr-div"></div>
            <div class="note-row-right">
              <div class="featured-content-desc">Content will appear here once posts are migrated. This card is a static placeholder for layout validation.</div>
              <div class="spacer-small"></div>
              <a href="/sample-test/" class="btn-read-more w-inline-block">
                <div class="featured-content-desc">Read More</div>
              </a>
            </div>
          </div>
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>

  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h2">Latest Notes</div>
        <div class="spacer-small"></div>
        <div class="note-container">
          <div class="note-row">
            <div class="note-row-left">
              <div class="subject-tag">Contract</div>
              <a href="/sample-test/" class="link-block w-inline-block">
                <div class="featured-content-desc">Sample placeholder note — replaced once content is migrated.</div>
              </a>
            </div>
            <div class="note-row-right">
              <div class="note-row-timestamp">— — —</div>
            </div>
          </div>
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>
</BaseLayout>
