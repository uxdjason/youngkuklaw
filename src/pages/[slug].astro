---
import { getCollection, render } from 'astro:content';
import CaseLayout from '../layouts/CaseLayout.astro';
import NoteLayout from '../layouts/NoteLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => {
    return data.lang === 'en' && !data.draft;
  });
  
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const isCase = post.data.category.endsWith('-cases') || post.data.category === 'case-law';

// Use seoTitle / metaDescription overrides when available (migrated content)
const displayTitle       = post.data.seoTitle       || post.data.title;
const displayDescription = post.data.metaDescription || post.data.description;
---
{isCase ? (
  <CaseLayout
    lang="en"
    slug={post.data.slug}
    category={post.data.category}
    title={displayTitle}
    description={displayDescription}
    citation={post.data.citation}
    court={post.data.court}
    claimant={post.data.claimant}
    defendant={post.data.defendant}
    courtLink={post.data.courtLink}
    pubDate={post.data.pubDate}
    modifiedDate={post.data.updatedDate}
  >
    <Content />
  </CaseLayout>
) : (
  <NoteLayout
    lang="en"
    slug={post.data.slug}
    category={post.data.category}
    title={displayTitle}
    description={displayDescription}
    pubDate={post.data.pubDate}
    modifiedDate={post.data.updatedDate}
  >
    <Content />
  </NoteLayout>
)}
