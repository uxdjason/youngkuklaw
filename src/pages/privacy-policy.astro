---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  lang="en"
  title="Privacy Policy · YoungkukLaw"
  description="Privacy Policy and data handling practices for the YoungkukLaw website."
>
  <section class="section">
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="article-block">
          <div
            class="article-body"
            style="width: 100%; max-width: 800px; margin: 0 auto;"
          >
            <div class="article-text w-richtext">
              <h1>Privacy Policy</h1>
              <br />

              <h2>Introduction</h2>
              <p>
                At YoungkukLaw, we are committed to protecting your privacy.
                This Privacy Policy explains how we handle your personal
                information and data when you visit and use our website.
              </p>

              <h2>Data Collection and Usage</h2>
              <p>
                We do not require users to create an account or provide personal
                information such as names or email addresses to access our
                content.
              </p>

              <h2>Local Storage</h2>
              <p>
                We use your browser's local storage to enhance your experience
                on our website. Specifically, we use local storage to remember
                your bookmarked articles so that they remain available when you
                return to the site. This data is stored strictly on your device
                and is never transmitted to our servers or shared with any third
                parties.
              </p>

              <h2>Third-Party Advertising and Cookies</h2>
              <p>
                We use Google AdSense to display advertisements on our website.
                Google AdSense uses cookies (including third-party cookies) to
                serve personalized ads based on your prior visits to our website
                or other websites on the internet.
              </p>
              <ul>
                <li>
                  Google's use of advertising cookies enables it and its
                  partners to serve ads to you based on your visit to our sites
                  and/or other sites on the Internet.
                </li>
                <li>
                  You may opt out of personalized advertising by visiting
                  Google's <a
                    href="https://www.google.com/settings/ads"
                    target="_blank"
                    rel="noopener">Ads Settings</a
                  >.
                </li>
              </ul>
              <p>
                Depending on your region (such as the European Economic Area or
                the UK), you may be presented with a consent banner allowing you
                to manage your cookie preferences for these advertisements.
              </p>

              <h2>Links to Other Websites</h2>
              <p>
                Our website may contain links to other websites of interest.
                However, once you have used these links to leave our site, you
                should note that we do not have any control over that other
                website. Therefore, we cannot be responsible for the protection
                and privacy of any information which you provide whilst visiting
                such sites and such sites are not governed by this privacy
                statement.
              </p>

              <h2>Changes to this Policy</h2>
              <p>
                We may update this Privacy Policy from time to time. Any changes
                will be posted on this page with an updated effective date. We
                encourage you to review this policy periodically.
              </p>

              <h2>Contact Us</h2>
              <p>
                If you have any questions about this Privacy Policy, please
                contact us at <a href="mailto:info@youngkuklaw.com">info@youngkuklaw.com</a>.
              </p>

              <hr />
              <p style="color: #666; font-size: 1em;">
                <strong>Effective Date:</strong> June 2026
              </p>
            </div>
          </div>
        </div>
        <div class="spacer-large"></div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>
</BaseLayout>
