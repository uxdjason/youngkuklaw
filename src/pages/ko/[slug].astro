---
import { getCollection, render } from 'astro:content';
import CaseLayout from '../../layouts/CaseLayout.astro';
import NoteLayout from '../../layouts/NoteLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => {
    return data.lang === 'ko' && !data.draft;
  });
  
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const isCase = post.data.category.endsWith('-cases') || post.data.category === 'case-law';

// H1 always uses post.data.title
const displayDescription = post.data.metaDescription || post.data.description;
---
{isCase ? (
  <CaseLayout
    lang="ko"
    slug={post.data.slug}
    category={post.data.category}
    title={post.data.title}
    seoTitle={post.data.seoTitle}
    description={displayDescription}
    citation={post.data.citation}
    court={post.data.court}
    claimantRole={post.data.claimantRole}
    claimant={post.data.claimant}
    defendantRole={post.data.defendantRole}
    defendant={post.data.defendant}
    courtLink={post.data.courtLink}
    pubDate={post.data.pubDate}
    modifiedDate={post.data.updatedDate}
  >
    <Content />
  </CaseLayout>
) : (
  <NoteLayout
    lang="ko"
    slug={post.data.slug}
    category={post.data.category}
    title={post.data.title}
    seoTitle={post.data.seoTitle}
    description={displayDescription}
    pubDate={post.data.pubDate}
    modifiedDate={post.data.updatedDate}
  >
    <Content />
  </NoteLayout>
)}
