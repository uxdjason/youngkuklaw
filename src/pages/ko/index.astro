---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS } from '../../utils/i18n';
import SearchBar from '../../components/SearchBar.astro';

const lang = 'ko';

// Featured: 3 cases
const featuredCases = await getCollection('posts', ({ data }) => {
  return data.lang === lang && data.category.endsWith('-cases') && !data.draft;
});
const slicedFeatured = featuredCases
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Latest Notes: 12 notes
const latestNotes = await getCollection('posts', ({ data }) => {
  return data.lang === lang && !data.category.endsWith('-cases') && !data.draft;
});
const sortedNotes = latestNotes
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);

function formatDate(date: Date) {
  return date.toLocaleDateString('ko-KR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}
---
<BaseLayout
  lang={lang}
  title="영국 Law — 영국법을 공부하는 한국인을 위한 무료 자료"
  description="영국법(계약·불법행위·공법·형사·형평·토지) 강의 노트와 판례 데이터베이스. 한국어 학습자를 위한 무료 리소스."
>
  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h1 align-center">영국법을 공부하는<br />한국인들을 위한 무료 리소스</div>
        <div class="spacer-small"></div>
        <div class="text-size-medium align-center">영국법의 각 과목별 노트와 광범위한 판례 데이터베이스를 무료로 이용하세요.</div>
        <div class="spacer-large"></div>
        <SearchBar lang={lang} />
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h2">주요 판례</div>
        <div class="spacer-small"></div>
        <div class="case-grid">
          {slicedFeatured.length === 0 ? (
            <div class="case-card">
              <div class="featured-content-desc ko">이용 가능한 판례가 없습니다.</div>
            </div>
          ) : (
            slicedFeatured.map(post => (
              <div class="case-card">
                <div class="case-card-upper">
                  <div class="subject-tag ko">{CATEGORY_LABELS[post.data.category]?.ko || '판례'}</div>
                  <a href={`/ko/${post.data.slug}/`} class="link-block w-inline-block">
                    <div class="heading-style-h4 ko">{post.data.title}</div>
                    {post.data.citation && <div class="case-citation-text ko">{post.data.citation}</div>}
                  </a>
                </div>
                <div class="hr-div"></div>
                <div class="note-row-right">
                  <div class="featured-content-desc ko">{post.data.description}</div>
                  <div class="spacer-small"></div>
                  <a href={`/ko/${post.data.slug}/`} class="btn-read-more ko w-inline-block">
                    <div class="featured-content-desc">더 보기</div>
                  </a>
                </div>
              </div>
            ))
          )}
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>

  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h2">최근 노트들</div>
        <div class="spacer-small"></div>
        <div class="note-container ko">
          {sortedNotes.length === 0 ? (
            <div class="note-row">
              <div class="featured-content-desc ko">이용 가능한 노트가 없습니다.</div>
            </div>
          ) : (
            sortedNotes.map((post, index) => (
              <>
                <div class="note-row">
                  <div class="note-row-left">
                    <div class="subject-tag ko">{CATEGORY_LABELS[post.data.category]?.ko || '노트'}</div>
                    <a href={`/ko/${post.data.slug}/`} class="link-block w-inline-block">
                      <div class="featured-content-desc ko">{post.data.title}</div>
                    </a>
                  </div>
                  <div class="note-row-right">
                    <div class="note-row-timestamp ko">{formatDate(post.data.pubDate)}</div>
                  </div>
                </div>
                {index < sortedNotes.length - 1 && <div class="hr-div no-margin"></div>}
              </>
            ))
          )}
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>

  {/* Bookmarked Section */}
  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="div-block">
          <div class="heading-style-h2">즐겨찾기</div>
          <div class="bookmark-icon-static w-embed">
            <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="7" y="5" width="10" height="13" fill="#FFC400"></rect>
              <path d="M5 21V5C5 4.45 5.19583 3.97917 5.5875 3.5875C5.97917 3.19583 6.45 3 7 3H17C17.55 3 18.0208 3.19583 18.4125 3.5875C18.8042 3.97917 19 4.45 19 5V21L12 18L5 21ZM7 17.95L12 15.8L17 17.95V5H7V17.95Z" fill="currentColor"></path>
            </svg>
          </div>
        </div>
        <div class="spacer-small"></div>
        <div class="note-container ko bookmark-list-container">
          <div class="div-block-2 no-bookmarks-msg">
            <div>즐겨찾기에 추가된 내용이 없습니다.</div>
          </div>
        </div>
        <div class="spacer-large"></div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>
</BaseLayout>

{/* Fetch all published posts to map them in JavaScript for dynamic bookmark rendering */}
{(() => {
  async function getBookmarkData() {
    const allPostsForBookmark = await getCollection('posts', ({ data }) => {
      return data.lang === lang && !data.draft;
    });
    return allPostsForBookmark.map(post => ({
      slug: post.data.slug,
      title: post.data.title,
      url: `/ko/${post.data.slug}/`,
      categoryLabel: CATEGORY_LABELS[post.data.category]?.ko || '노트',
      pubDate: post.data.pubDate,
    }));
  }
  
  return getBookmarkData().then(bookmarkDb => (
    <script define:vars={{ bookmarkDb, lang }}>
      const renderBookmarks = () => {
        const listContainer = document.querySelector('.bookmark-list-container');
        if (!listContainer) return;
        
        // Clear previous dynamically rendered items
        listContainer.querySelectorAll('.note-row:not(.no-bookmarks-msg), .hr-div').forEach(el => el.remove());
        
        const noBookmarksMsg = listContainer.querySelector('.no-bookmarks-msg');
        
        const bookmarkedSlugs = JSON.parse(localStorage.getItem('bookmarked_posts') || '[]');
        const bookmarkDates: Record<string, string> = JSON.parse(localStorage.getItem('bookmark_dates') || '{}');
        const bookmarkedPosts = bookmarkDb.filter(post => bookmarkedSlugs.includes(post.slug));
        
        if (bookmarkedPosts.length > 0) {
          if (noBookmarksMsg) noBookmarksMsg.style.display = 'none';
          
          bookmarkedPosts.forEach((post, index) => {
            const row = document.createElement('div');
            row.className = 'note-row';
            
            const rowLeft = document.createElement('div');
            rowLeft.className = 'note-row-left';
            
            const tag = document.createElement('div');
            tag.className = 'subject-tag ko';
            tag.textContent = post.categoryLabel;
            
            const link = document.createElement('a');
            link.className = 'link-block w-inline-block';
            link.href = post.url;
            
            const titleDiv = document.createElement('div');
            titleDiv.className = 'featured-content-desc ko';
            titleDiv.textContent = post.title;
            
            link.appendChild(titleDiv);
            rowLeft.appendChild(tag);
            rowLeft.appendChild(link);
            
            const rowRight = document.createElement('div');
            rowRight.className = 'note-row-right';
            
            const timestamp = document.createElement('div');
            timestamp.className = 'note-row-timestamp ko';
            
            const rawDate = bookmarkDates[post.slug];
            if (rawDate) {
              const formattedDate = new Date(rawDate).toLocaleDateString('ko-KR', {
                day: 'numeric',
                month: 'long',
                year: 'numeric'
              });
              timestamp.textContent = formattedDate + '에 추가';
            } else {
              timestamp.textContent = '추가 날짜 불명';
            }
            
            rowRight.appendChild(timestamp);
            row.appendChild(rowLeft);
            row.appendChild(rowRight);
            
            listContainer.appendChild(row);
            
            if (index < bookmarkedPosts.length - 1) {
              const hr = document.createElement('div');
              hr.className = 'hr-div no-margin';
              listContainer.appendChild(hr);
            }
          });
        } else {
          if (noBookmarksMsg) noBookmarksMsg.style.display = 'block';
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', renderBookmarks);
      } else {
        renderBookmarks();
      }
      window.addEventListener('bookmark-updated', renderBookmarks);
    </script>
  ));
})()}

