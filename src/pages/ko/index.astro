---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS } from '../../utils/i18n';
import SearchBar from '../../components/SearchBar.astro';

const lang = 'ko';

// Featured: 3 cases
const featuredCases = await getCollection('posts', ({ data }) => {
  return data.lang === lang && data.category.endsWith('-cases') && !data.draft;
});
const slicedFeatured = featuredCases
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Latest Notes: 12 notes
const latestNotes = await getCollection('posts', ({ data }) => {
  return data.lang === lang && !data.category.endsWith('-cases') && !data.draft;
});
const sortedNotes = latestNotes
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 12);

function formatDate(date: Date) {
  return date.toLocaleDateString('ko-KR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}
---
<BaseLayout
  lang={lang}
  title="영국 Law — 영국법을 공부하는 한국인을 위한 무료 자료"
  description="영국법(계약·불법행위·공법·형사·형평·토지) 강의 노트와 판례 데이터베이스. 한국어 학습자를 위한 무료 리소스."
>
  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h1 align-center">영국법을 공부하는<br />한국인들을 위한 무료 리소스</div>
        <div class="spacer-small"></div>
        <div class="text-size-medium align-center">영국법의 각 과목별 노트와 광범위한 판례 데이터베이스를 무료로 이용하세요.</div>
        <div class="spacer-large"></div>
        <SearchBar lang={lang} />
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h2">주요 판례</div>
        <div class="spacer-small"></div>
        <div class="case-grid">
          {slicedFeatured.length === 0 ? (
            <div class="case-card">
              <div class="featured-content-desc ko">이용 가능한 판례가 없습니다.</div>
            </div>
          ) : (
            slicedFeatured.map(post => (
              <div class="case-card">
                <div class="case-card-upper">
                  <div class="subject-tag ko">{CATEGORY_LABELS[post.data.category]?.ko || '판례'}</div>
                  <a href={`/ko/${post.data.slug}/`} class="link-block w-inline-block">
                    <div class="heading-style-h4 ko">{post.data.title}</div>
                    {post.data.citation && <div class="case-citation-text ko">{post.data.citation}</div>}
                  </a>
                </div>
                <div class="hr-div"></div>
                <div class="note-row-right">
                  <div class="featured-content-desc ko">{post.data.description}</div>
                  <div class="spacer-small"></div>
                  <a href={`/ko/${post.data.slug}/`} class="btn-read-more ko w-inline-block">
                    <div class="featured-content-desc">더 보기</div>
                  </a>
                </div>
              </div>
            ))
          )}
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>

  <section>
    <div class="padding-global">
      <div class="container-large">
        <div class="spacer-large"></div>
        <div class="heading-style-h2">최근 노트들</div>
        <div class="spacer-small"></div>
        <div class="note-container ko">
          {sortedNotes.length === 0 ? (
            <div class="note-row">
              <div class="featured-content-desc ko">이용 가능한 노트가 없습니다.</div>
            </div>
          ) : (
            sortedNotes.map((post, index) => (
              <>
                <div class="note-row">
                  <div class="note-row-left">
                    <div class="subject-tag ko">{CATEGORY_LABELS[post.data.category]?.ko || '노트'}</div>
                    <a href={`/ko/${post.data.slug}/`} class="link-block w-inline-block">
                      <div class="featured-content-desc ko">{post.data.title}</div>
                    </a>
                  </div>
                  <div class="note-row-right">
                    <div class="note-row-timestamp ko">{formatDate(post.data.pubDate)}</div>
                  </div>
                </div>
                {index < sortedNotes.length - 1 && <div class="hr-div no-margin"></div>}
              </>
            ))
          )}
        </div>
        <div class="spacer-large"></div>
      </div>
    </div>
  </section>
</BaseLayout>
