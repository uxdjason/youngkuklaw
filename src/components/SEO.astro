---
import type { Lang } from '../utils/i18n';
import { SITE_URL, oppositeLocalePath } from '../utils/i18n';

// Canonical URL of the default OG / share image (used as fallback for every page)
const DEFAULT_OG_IMAGE = `${SITE_URL}/images/og-default.png`;
const OG_IMAGE_WIDTH  = 1200;
const OG_IMAGE_HEIGHT = 630;
const LOGO_URL        = `${SITE_URL}/images/youngkuklaw-logo-260519.png`;

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  noindex?: boolean;
}

const {
  lang,
  title,
  description = '',
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  breadcrumbs,
  noindex = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonical   = new URL(currentPath, SITE_URL).toString();
const oppositePath = oppositeLocalePath(currentPath, lang);
const oppositeUrl  = new URL(oppositePath, SITE_URL).toString();
const xDefaultUrl  =
  lang === 'en' ? canonical : new URL(oppositePath, SITE_URL).toString();

const ogLocale = lang === 'en' ? 'en_GB' : 'ko_KR';

// Always resolve to an absolute URL; fall back to the site-wide default OG image
const ogImageUrl = image
  ? (image.startsWith('http') ? image : new URL(image, SITE_URL).toString())
  : DEFAULT_OG_IMAGE;

// Human-readable alt for the OG image
const ogImageAlt =
  lang === 'en'
    ? 'YoungkukLaw – Study English Law, Clear Notes, Real Cases'
    : 'YoungkukLaw – 영국법 학습 노트 및 판례 데이터베이스';

// Organisation schema block (shared)
const orgSchema = {
  '@type': 'Organization',
  name: 'YoungkukLaw',
  url: SITE_URL,
  logo: {
    '@type': 'ImageObject',
    url: LOGO_URL,
  },
};

const articleSchema =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        ...(description ? { description } : {}),
        inLanguage: lang === 'en' ? 'en-GB' : 'ko-KR',
        url: canonical,
        ...(publishedTime ? { datePublished: publishedTime } : {}),
        ...(modifiedTime  ? { dateModified:  modifiedTime  } : {}),
        image: {
          '@type': 'ImageObject',
          url: ogImageUrl,
          width: OG_IMAGE_WIDTH,
          height: OG_IMAGE_HEIGHT,
        },
        publisher: orgSchema,
        author: orgSchema,
      }
    : null;

const websiteSchema =
  type === 'website'
    ? {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'YoungkukLaw',
        url: SITE_URL,
        description:
          lang === 'en'
            ? 'Quality lecture notes and a vast database of cases for law students worldwide.'
            : '영국법 강의 노트와 방대한 판례 데이터베이스를 무료로 제공하는 영국법 학습 플랫폼.',
        inLanguage: lang === 'en' ? 'en-GB' : 'ko-KR',
        publisher: orgSchema,
        potentialAction: {
          '@type': 'SearchAction',
          target: {
            '@type': 'EntryPoint',
            urlTemplate: `${SITE_URL}/search?q={search_term_string}`,
          },
          'query-input': 'required name=search_term_string',
        },
      }
    : null;

const breadcrumbSchema =
  breadcrumbs && breadcrumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((b, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: b.name,
          item: new URL(b.url, SITE_URL).toString(),
        })),
      }
    : null;
---
<title>{title}</title>
{description && <meta name="description" content={description} />}
<link rel="canonical" href={canonical} />

{/* hreflang — every page declares en, ko, and x-default */}
<link rel="alternate" hreflang="en" href={lang === 'en' ? canonical : oppositeUrl} />
<link rel="alternate" hreflang="ko" href={lang === 'ko' ? canonical : oppositeUrl} />
<link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

{noindex && <meta name="robots" content="noindex,follow" />}

{/* ── Open Graph ──────────────────────────────────────────────── */}
<meta property="og:locale"    content={ogLocale} />
<meta property="og:type"      content={type} />
<meta property="og:site_name" content="YoungkukLaw" />
<meta property="og:title"     content={title} />
{description && <meta property="og:description" content={description} />}
<meta property="og:url"       content={canonical} />

{/* OG image — always present (falls back to site-wide default) */}
<meta property="og:image"        content={ogImageUrl} />
<meta property="og:image:secure_url" content={ogImageUrl} />
<meta property="og:image:width"  content={String(OG_IMAGE_WIDTH)} />
<meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
<meta property="og:image:type"   content="image/png" />
<meta property="og:image:alt"    content={ogImageAlt} />

{/* OG logo (used by some platforms e.g. LinkedIn) */}
<meta property="og:logo" content={LOGO_URL} />

{/* Article-specific OG properties */}
{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === 'article' && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{type === 'article' && (
  <meta property="article:author" content={SITE_URL} />
)}

{/* ── Twitter / X Card ────────────────────────────────────────── */}
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:site"        content="@youngkuklaw" />
<meta name="twitter:title"       content={title} />
{description && <meta name="twitter:description" content={description} />}
<meta name="twitter:image"       content={ogImageUrl} />
<meta name="twitter:image:alt"   content={ogImageAlt} />

{/* ── Structured Data (JSON-LD) ───────────────────────────────── */}
{articleSchema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}
{websiteSchema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
)}
{breadcrumbSchema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}
