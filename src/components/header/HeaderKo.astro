---
const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  currentPath === href || currentPath === href + "/";
---

<div
  data-animation="default"
  data-collapse="medium"
  data-duration="400"
  data-easing="ease"
  data-easing2="ease"
  role="banner"
  class="nav_component w-nav"
>
  <div class="padding-global">
    <div class="nav_container">
      <a
        href="/ko/"
        class:list={[
          "nav_brand",
          "w-nav-brand",
          isActive("/ko/") && "w--current",
        ]}
        aria-current={isActive("/ko/") ? "page" : undefined}
      >
        <div class="text-block-11">영국Law</div>
      </a>
      <nav role="navigation" class="nav_menu w-nav-menu">
        <a href="/ko/english-law/" class="nav_menu_link ko w-nav-link"
          >영국법 일반</a
        >
        <div data-hover="false" data-delay="0" class="dropdown ko w-dropdown">
          <div class="dropdown-toggle ko w-dropdown-toggle">
            <div>판례</div>
            <div class="chevron-down w-embed">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                height="1em"
                viewBox="0 -960 960 960"
                width="1em"
                fill="currentColor"
              >
                <path d="M480-344 240-584l56-56 184 184 184-184 56 56-240 240Z"
                ></path>
              </svg>
            </div>
            <div class="chevron-up w-embed">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                height="1em"
                viewBox="0 -960 960 960"
                width="1em"
                fill="currentColor"
              >
                <path d="M480-528 296-344l-56-56 240-240 240 240-56 56-184-184Z"
                ></path>
              </svg>
            </div>
          </div>
          <nav class="dropdown-list w-dropdown-list">
            <div class="subnav_container">
              <a href="/ko/case-law/" class="dropdown-link w-dropdown-link"
                >모든 판례</a
              >
              <a
                href="/ko/contract-law-cases/"
                class="dropdown-link w-dropdown-link">계약법 판례</a
              >
              <a
                href="/ko/tort-law-cases/"
                class="dropdown-link w-dropdown-link">불법행위법 판례</a
              >
              <a
                href="/ko/public-law-cases/"
                class="dropdown-link w-dropdown-link">공법 판례</a
              >
              <a
                href="/ko/criminal-law-cases/"
                class="dropdown-link w-dropdown-link">형사법 판례</a
              >
              <a
                href="/ko/equity-law-cases/"
                class="dropdown-link w-dropdown-link">형평법 판례</a
              >
              <a
                href="/ko/land-law-cases/"
                class="dropdown-link w-dropdown-link">토지법 판례</a
              >
            </div>
          </nav>
        </div>
        <a href="/ko/contract-law/" class="nav_menu_link ko w-nav-link"
          >계약법</a
        >
        <a href="/ko/tort-law/" class="nav_menu_link ko w-nav-link"
          >불법행위법</a
        >
        <a href="/ko/public-law/" class="nav_menu_link ko w-nav-link">공법</a>
        <a href="/ko/criminal-law/" class="nav_menu_link ko w-nav-link"
          >형사법</a
        >
        <a href="/ko/equity-law/" class="nav_menu_link ko w-nav-link">형평법</a>
        <a href="/ko/land-law/" class="nav_menu_link ko w-nav-link">토지법</a>
      </nav>
      <div class="nav_button w-nav-button">
        <div class="burger_icon w-embed">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            height="1em"
            viewBox="0 -960 960 960"
            width="1em"
            fill="currentColor"
          >
            <path
              d="M120-240v-80h720v80H120Zm0-200v-80h720v80H120Zm0-200v-80h720v80H120Z"
            ></path>
          </svg>
        </div>
        <div class="close_icon w-embed">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            height="1em"
            viewBox="0 -960 960 960"
            width="1em"
            fill="currentColor"
          >
            <path
              d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z"
            ></path>
          </svg>
        </div>
      </div>
    </div>
  </div>
</div>
