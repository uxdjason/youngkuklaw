---
import type { Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const message =
  lang === 'en'
    ? 'YoungkukLaw is free and ad-supported. Please consider whitelisting this site in your ad blocker — it keeps the notes coming.'
    : '영국로(YoungkukLaw)는 광고로 운영되는 무료 사이트입니다. 광고 차단을 해제해 주시면 더 많은 자료를 무료로 제공할 수 있습니다.';
const closeLabel = lang === 'en' ? 'Dismiss' : '닫기';
---
<div
  class={`adblock-banner${lang === 'ko' ? ' ko' : ''}`}
  data-adblock-banner
  hidden
  role="status"
>
  <span>{message}</span>
  <button
    type="button"
    class="adblock-banner__close"
    data-adblock-dismiss
    aria-label={closeLabel}
  >×</button>
</div>

<script>
  const STORAGE_KEY = 'ykl-adblock-banner-dismissed';

  function isElementBlocked(el: HTMLElement): boolean {
    const cs = window.getComputedStyle(el);
    return (
      el.offsetParent === null ||
      el.offsetHeight === 0 ||
      el.clientHeight === 0 ||
      cs.display === 'none' ||
      cs.visibility === 'hidden'
    );
  }

  function detect(): void {
    const banner = document.querySelector('[data-adblock-banner]') as HTMLElement | null;
    if (!banner) return;

    if (sessionStorage.getItem(STORAGE_KEY) === '1') return;

    // Multiple bait elements with class names commonly hit by ad-block filter
    // lists. If any of them is hidden / removed, we treat the user as blocking.
    const baits: HTMLElement[] = [];
    const make = (cls: string) => {
      const el = document.createElement('div');
      el.className = cls;
      el.innerHTML = '&nbsp;';
      el.style.cssText =
        'position:absolute; left:-9999px; top:-9999px; width:1px; height:1px; pointer-events:none;';
      document.body.appendChild(el);
      baits.push(el);
    };
    make('adsbox');
    make('adsbygoogle ad-placement');
    make('ad-banner ad-container');

    const baitIns = document.createElement('ins');
    baitIns.className = 'adsbygoogle';
    baitIns.style.cssText =
      'position:absolute; left:-9999px; top:-9999px; display:block; width:1px; height:1px;';
    document.body.appendChild(baitIns);
    baits.push(baitIns);

    window.setTimeout(() => {
      const blocked = baits.some(isElementBlocked);
      if (blocked) banner.hidden = false;
      baits.forEach((el) => el.remove());
    }, 300);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', detect, { once: true });
  } else {
    detect();
  }

  document.querySelector('[data-adblock-dismiss]')?.addEventListener('click', () => {
    const banner = document.querySelector('[data-adblock-banner]') as HTMLElement | null;
    if (banner) banner.hidden = true;
    try {
      sessionStorage.setItem(STORAGE_KEY, '1');
    } catch {
      /* sessionStorage unavailable — banner stays dismissed for this view */
    }
  });
</script>
